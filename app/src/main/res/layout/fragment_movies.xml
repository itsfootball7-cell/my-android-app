<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@color/bg_primary">

    <!-- LEFT: Genre Categories -->
    <LinearLayout
        android:layout_width="140dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/bg_sidebar">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="GENRES"
            android:textColor="#4DFFFFFF"
            android:textSize="9sp"
            android:letterSpacing="0.1"
            android:padding="12dp"
            android:paddingBottom="4dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvCategories"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="6dp"/>
    </LinearLayout>

    <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#14FFFFFF"/>

    <!-- MIDDLE: Movie Grid -->
    <LinearLayout
        android:layout_width="240dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/bg_middle">

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:layout_margin="8dp"
            android:hint="Search movies..."
            android:textColorHint="#40FFFFFF"
            android:textColor="@color/white"
            android:textSize="11sp"
            android:background="@drawable/input_bg"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"/>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"
            android:indeterminateTint="@color/accent_orange"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvMovies"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="6dp"/>
    </LinearLayout>

    <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#14FFFFFF"/>

    <!-- RIGHT: Movie Detail -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <ImageView
                android:id="@+id/ivMoviePoster"
                android:layout_width="70dp"
                android:layout_height="100dp"
                android:scaleType="centerCrop"
                android:background="@drawable/poster_placeholder"
                android:layout_marginEnd="14dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvMovieTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:id="@+id/tvMovieYear"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#80FFFFFF"
                        android:textSize="11sp"
                        android:background="@drawable/badge_info"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="2dp"
                        android:paddingBottom="2dp"
                        android:layout_marginEnd="6dp"/>

                    <TextView
                        android:id="@+id/tvMovieRating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/accent_orange"
                        android:textSize="12sp"/>

                </LinearLayout>

                <Button
                    android:id="@+id/btnPlay"
                    android:layout_width="140dp"
                    android:layout_height="38dp"
                    android:text="▶  Play Now"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:background="@drawable/btn_primary"
                    android:layout_marginTop="8dp"/>

            </LinearLayout>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="0.5dp"
            android:background="#14FFFFFF" android:layout_marginBottom="10dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SYNOPSIS"
            android:textColor="#4DFFFFFF"
            android:textSize="9sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tvMoviePlot"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#99FFFFFF"
            android:textSize="12sp"
            android:lineSpacingMultiplier="1.5"/>

    </LinearLayout>
</LinearLayout>
