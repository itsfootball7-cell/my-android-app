<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary"
    android:padding="20dp">

    <!-- ── Top Row: DateTime + Master Search ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp">

        <TextView
            android:id="@+id/tvDateTime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#80FFFFFF"
            android:textSize="13sp"/>

        <!-- Master Search pill button -->
        <LinearLayout
            android:id="@+id/btnMasterSearch"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:background="@drawable/search_pill_bg"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔍"
                android:textSize="16sp"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Master Search"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"/>

        </LinearLayout>

    </LinearLayout>

    <!-- ── Content Cards Row: LIVE TV | MOVIES | SERIES ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <!-- ─── LIVE TV CARD ─── -->
        <LinearLayout
            android:id="@+id/cardLiveTv"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/dashboard_card_bg"
            android:layout_marginEnd="12dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="@drawable/ripple_overlay">

            <!-- Icon area with circular progress ring -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="center">

                <!-- Circular arc ring -->
                <com.nitro.tvplayer.ui.home.CircularProgressView
                    android:id="@+id/circularLive"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_gravity="center"/>

                <!-- Center content: icon + title -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📡"
                        android:textSize="32sp"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LIVE TV"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvLiveTvCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#80FFFFFF"
                        android:textSize="10sp"
                        android:layout_marginTop="2dp"
                        android:visibility="gone"/>

                </LinearLayout>

            </FrameLayout>

            <!-- Bottom bar: last updated + refresh -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="8dp"
                android:background="@drawable/card_bottom_bar">

                <TextView
                    android:id="@+id/tvLiveTvUpdated"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Last updated: —"
                    android:textColor="#80FFFFFF"
                    android:textSize="9sp"
                    android:maxLines="1"
                    android:ellipsize="end"/>

                <TextView
                    android:id="@+id/btnRefreshLive"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:text="↺"
                    android:textSize="16sp"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:background="@drawable/refresh_btn_bg"/>

            </LinearLayout>

        </LinearLayout>

        <!-- ─── MOVIES CARD ─── -->
        <LinearLayout
            android:id="@+id/cardMovies"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/dashboard_card_bg"
            android:layout_marginEnd="12dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="@drawable/ripple_overlay">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="center">

                <com.nitro.tvplayer.ui.home.CircularProgressView
                    android:id="@+id/circularMovies"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_gravity="center"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎬"
                        android:textSize="32sp"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MOVIES"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvMoviesCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#80FFFFFF"
                        android:textSize="10sp"
                        android:layout_marginTop="2dp"
                        android:visibility="gone"/>

                </LinearLayout>

            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="8dp"
                android:background="@drawable/card_bottom_bar">

                <TextView
                    android:id="@+id/tvMoviesUpdated"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Last updated: —"
                    android:textColor="#80FFFFFF"
                    android:textSize="9sp"
                    android:maxLines="1"
                    android:ellipsize="end"/>

                <TextView
                    android:id="@+id/btnRefreshMovies"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:text="↺"
                    android:textSize="16sp"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:background="@drawable/refresh_btn_bg"/>

            </LinearLayout>

        </LinearLayout>

        <!-- ─── SERIES CARD ─── -->
        <LinearLayout
            android:id="@+id/cardSeries"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/dashboard_card_bg"
            android:clickable="true"
            android:focusable="true"
            android:foreground="@drawable/ripple_overlay">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="center">

                <com.nitro.tvplayer.ui.home.CircularProgressView
                    android:id="@+id/circularSeries"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_gravity="center"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="▶"
                        android:textSize="32sp"
                        android:textColor="#FFFFFF"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SERIES"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvSeriesCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#80FFFFFF"
                        android:textSize="10sp"
                        android:layout_marginTop="2dp"
                        android:visibility="gone"/>

                </LinearLayout>

            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="8dp"
                android:background="@drawable/card_bottom_bar">

                <TextView
                    android:id="@+id/tvSeriesUpdated"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Last updated: —"
                    android:textColor="#80FFFFFF"
                    android:textSize="9sp"
                    android:maxLines="1"
                    android:ellipsize="end"/>

                <TextView
                    android:id="@+id/btnRefreshSeries"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:text="↺"
                    android:textSize="16sp"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:background="@drawable/refresh_btn_bg"/>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- ── Quick Actions Row ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:layout_marginBottom="14dp">

        <LinearLayout
            android:id="@+id/cardSearch"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/dashboard_action_bg"
            android:layout_marginEnd="12dp"
            android:clickable="true"
            android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🔍" android:textSize="16sp" android:layout_marginEnd="8dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="MASTER SEARCH" android:textColor="#FFFFFF"
                android:textSize="12sp" android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardSettings"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/dashboard_action_bg"
            android:layout_marginEnd="12dp"
            android:clickable="true"
            android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="⚙️" android:textSize="16sp" android:layout_marginEnd="8dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="SETTINGS" android:textColor="#FFFFFF"
                android:textSize="12sp" android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardSubscription"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/dashboard_action_bg"
            android:clickable="true"
            android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="👤" android:textSize="16sp" android:layout_marginEnd="8dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="ACCOUNT" android:textColor="#FFFFFF"
                android:textSize="12sp" android:textStyle="bold"/>
        </LinearLayout>

    </LinearLayout>

    <!-- ── Footer: Expiry + Logged in ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <TextView
            android:id="@+id/tvExpiry"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#80FFFFFF"
            android:textSize="12sp"
            android:gravity="center"/>

        <TextView
            android:id="@+id/tvLoggedIn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center"/>

    </LinearLayout>

</LinearLayout>
