<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@color/bg_primary">

    <!-- LEFT: Categories -->
    <LinearLayout
        android:layout_width="140dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/bg_sidebar">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="GENRES"
            android:textColor="#4DFFFFFF"
            android:textSize="9sp"
            android:letterSpacing="0.1"
            android:padding="12dp"
            android:paddingBottom="4dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvCategories"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="6dp"/>

    </LinearLayout>

    <View android:layout_width="1dp" android:layout_height="match_parent"
        android:background="#14FFFFFF"/>

    <!-- MIDDLE: Series Grid -->
    <LinearLayout
        android:layout_width="220dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/bg_middle">

        <!-- Search bar — always visible -->
        <EditText
            android:id="@+id/etSearch"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:layout_margin="8dp"
            android:hint="Search series..."
            android:textColorHint="#40FFFFFF"
            android:textColor="@color/white"
            android:textSize="11sp"
            android:background="@drawable/input_bg"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:inputType="text"
            android:imeOptions="actionSearch"
            android:singleLine="true"/>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"
            android:indeterminateTint="@color/accent_orange"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvSeries"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="4dp"
            android:clipToPadding="false"/>

    </LinearLayout>

    <View android:layout_width="1dp" android:layout_height="match_parent"
        android:background="#14FFFFFF"/>

    <!-- RIGHT: Series Detail + Episodes -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Series info header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <ImageView
                android:id="@+id/ivSeriesCover"
                android:layout_width="60dp"
                android:layout_height="86dp"
                android:scaleType="centerCrop"
                android:background="@drawable/poster_placeholder"
                android:layout_marginEnd="12dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvSeriesTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvSeriesInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#80FFFFFF"
                    android:textSize="11sp"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvSeriesRating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/accent_orange"
                    android:textSize="12sp"/>

            </LinearLayout>
        </LinearLayout>

        <!-- Season selector -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvSeasons"
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:layout_marginBottom="8dp"/>

        <!-- Plot -->
        <TextView
            android:id="@+id/tvSeriesPlot"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#80FFFFFF"
            android:textSize="11sp"
            android:lineSpacingMultiplier="1.5"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginBottom="8dp"/>

        <View android:layout_width="match_parent" android:layout_height="0.5dp"
            android:background="#14FFFFFF" android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EPISODES"
            android:textColor="#4DFFFFFF"
            android:textSize="9sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="6dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvEpisodes"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>

    </LinearLayout>

</LinearLayout>
