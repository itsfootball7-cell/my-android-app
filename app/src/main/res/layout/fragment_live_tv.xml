<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@color/bg_primary">

    <!-- LEFT: Categories -->
    <LinearLayout
        android:layout_width="140dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/bg_sidebar">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CATEGORIES"
            android:textColor="#4DFFFFFF"
            android:textSize="9sp"
            android:letterSpacing="0.1"
            android:padding="12dp"
            android:paddingBottom="4dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvCategories"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:padding="6dp"/>

    </LinearLayout>

    <!-- Divider -->
    <View android:layout_width="1dp" android:layout_height="match_parent"
        android:background="#14FFFFFF"/>

    <!-- MIDDLE: Streams -->
    <LinearLayout
        android:layout_width="200dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/bg_middle">

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:layout_margin="8dp"
            android:hint="Search channels..."
            android:textColorHint="#40FFFFFF"
            android:textColor="@color/white"
            android:textSize="11sp"
            android:background="@drawable/input_bg"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvStreams"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:padding="6dp"/>

    </LinearLayout>

    <!-- Divider -->
    <View android:layout_width="1dp" android:layout_height="match_parent"
        android:background="#14FFFFFF"/>

    <!-- RIGHT: Preview + Info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="10dp">

        <!-- Video Preview Placeholder -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@drawable/player_preview_bg">

            <ImageView
                android:id="@+id/ivChannelLogo"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_gravity="center"
                android:scaleType="fitCenter"/>

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone"
                android:indeterminateTint="@color/accent_orange"/>

            <TextView
                android:id="@+id/tvError"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:textColor="#FFCF6679"
                android:textSize="11sp"
                android:visibility="gone"/>

            <!-- Play button overlay -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:background="#80000000"
                android:orientation="horizontal"
                android:padding="10dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvChannelName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvLiveBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="● LIVE"
                    android:textColor="@color/white"
                    android:textSize="9sp"
                    android:background="@drawable/badge_live"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"
                    android:layout_marginEnd="8dp"
                    android:visibility="gone"/>

                <Button
                    android:id="@+id/btnPlay"
                    android:layout_width="100dp"
                    android:layout_height="36dp"
                    android:text="▶ Watch"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:background="@drawable/btn_primary"/>

            </LinearLayout>
        </FrameLayout>

    </LinearLayout>

</LinearLayout>
