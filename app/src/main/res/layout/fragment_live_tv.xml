<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@color/bg_primary">

    <!-- ── LEFT: Category sidebar ── -->
    <LinearLayout
        android:layout_width="160dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/bg_sidebar">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="GENRES"
            android:textColor="#40FFFFFF"
            android:textSize="9sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:paddingStart="12dp"
            android:paddingTop="12dp"
            android:paddingBottom="6dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvCategories"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"/>

    </LinearLayout>

    <!-- ── MIDDLE: Channel list ── -->
    <LinearLayout
        android:layout_width="220dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/bg_middle">

        <!-- Section header with search icon -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="8dp"
            android:background="@color/bg_header">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="CHANNELS"
                android:textColor="#60FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"/>

            <!-- Search icon button -->
            <TextView
                android:id="@+id/btnSearch"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="🔍"
                android:textSize="16sp"
                android:gravity="center"
                android:background="@drawable/btn_player_control"
                android:clickable="true"
                android:focusable="true"/>

        </LinearLayout>

        <!-- Search bar (hidden by default) -->
        <LinearLayout
            android:id="@+id/searchBarContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="6dp"
            android:paddingBottom="4dp"
            android:background="@color/bg_header"
            android:visibility="gone">

            <EditText
                android:id="@+id/etSearch"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:hint="Search channels..."
                android:textColor="#FFFFFF"
                android:textColorHint="#60FFFFFF"
                android:textSize="12sp"
                android:background="@drawable/input_bg"
                android:paddingStart="12dp"
                android:paddingEnd="8dp"
                android:inputType="text"
                android:singleLine="true"
                android:imeOptions="actionSearch"
                android:layout_marginEnd="6dp"/>

            <TextView
                android:id="@+id/btnClearSearch"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:text="✕"
                android:textSize="12sp"
                android:textColor="#80FFFFFF"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"/>

        </LinearLayout>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:indeterminateTint="@color/accent_orange"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:indeterminate="true"
            android:visibility="gone"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvStreams"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"/>

    </LinearLayout>

    <!-- ── RIGHT: Preview panel ── -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@color/bg_primary">

        <!-- Channel info bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@color/bg_header">

            <ImageView
                android:id="@+id/ivChannelLogo"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:scaleType="fitCenter"
                android:layout_marginEnd="10dp"/>

            <TextView
                android:id="@+id/tvChannelName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tvLiveBadge"
                android:layout_width="wrap_content"
                android:layout_height="22dp"
                android:text=" LIVE "
                android:textColor="#FFFFFF"
                android:textSize="9sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="#CCCC0000"
                android:visibility="gone"/>

        </LinearLayout>

        <!-- Preview player -->
        <FrameLayout
            android:id="@+id/previewContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#000000"
            android:clickable="true"
            android:focusable="true">

            <androidx.media3.ui.PlayerView
                android:id="@+id/previewPlayerView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>

            <ImageView
                android:id="@+id/ivChannelLogoLarge"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_gravity="center"
                android:scaleType="fitCenter"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/tapHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Select a channel to preview"
                android:textColor="#40FFFFFF"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/tvClickToWatch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:text="▶  Tap to watch fullscreen"
                android:textColor="#CCFFFFFF"
                android:textSize="11sp"
                android:gravity="center"
                android:padding="8dp"
                android:background="#88000000"
                android:visibility="gone"/>

        </FrameLayout>

    </LinearLayout>

</LinearLayout>
