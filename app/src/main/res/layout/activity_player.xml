<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent" android:background="#000000">

    <androidx.media3.ui.PlayerView android:id="@+id/playerView"
        android:layout_width="match_parent" android:layout_height="match_parent" android:keepScreenOn="true"/>

    <View android:id="@+id/touchOverlay" android:layout_width="match_parent" android:layout_height="match_parent"
        android:background="#00000000" android:clickable="true" android:focusable="true"/>

    <ProgressBar android:id="@+id/progressBar" android:layout_width="52dp" android:layout_height="52dp"
        android:layout_gravity="center" android:visibility="gone" android:indeterminateTint="#FFB300"/>

    <TextView android:id="@+id/tvError" android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="center" android:textColor="#FFCF6679" android:textSize="13sp"
        android:visibility="gone" android:padding="12dp" android:background="#90000000"/>

    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="top|start" android:layout_margin="14dp" android:orientation="horizontal" android:alpha="0.35">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Nitro" android:textColor="#FFFFFF" android:textSize="11sp" android:textStyle="bold"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Tv" android:textColor="#FFB300" android:textSize="9sp" android:textStyle="bold" android:layout_marginStart="2dp"/>
    </LinearLayout>

    <!-- LEFT: Brightness bar -->
    <LinearLayout android:id="@+id/leftBarContainer" android:layout_width="32dp" android:layout_height="200dp"
        android:layout_gravity="center_vertical|start" android:layout_marginStart="10dp"
        android:orientation="vertical" android:gravity="center_horizontal"
        android:background="#99000000" android:padding="6dp" android:visibility="invisible" android:alpha="0">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="☀" android:textColor="#4FC3F7" android:textSize="13sp" android:layout_marginBottom="4dp"/>
        <FrameLayout android:layout_width="6dp" android:layout_height="140dp" android:background="#33FFFFFF">
            <View android:id="@+id/leftBrightnessBarFill" android:layout_width="6dp" android:layout_height="70dp"
                android:layout_gravity="bottom" android:background="#4FC3F7"/>
        </FrameLayout>
        <ProgressBar android:id="@+id/leftBrightnessBar" style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="0dp" android:layout_height="0dp" android:max="100" android:progress="50" android:visibility="gone"/>
        <TextView android:id="@+id/tvBrightnessValue" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="50%" android:textColor="#CCFFFFFF" android:textSize="8sp" android:layout_marginTop="4dp"/>
    </LinearLayout>

    <!-- RIGHT: Volume bar -->
    <LinearLayout android:id="@+id/rightBarContainer" android:layout_width="32dp" android:layout_height="200dp"
        android:layout_gravity="center_vertical|end" android:layout_marginEnd="10dp"
        android:orientation="vertical" android:gravity="center_horizontal"
        android:background="#99000000" android:padding="6dp" android:visibility="invisible" android:alpha="0">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="&#128266;" android:textSize="12sp" android:layout_marginBottom="4dp"/>
        <FrameLayout android:layout_width="6dp" android:layout_height="140dp" android:background="#33FFFFFF">
            <View android:id="@+id/rightVolumeBarFill" android:layout_width="6dp" android:layout_height="70dp"
                android:layout_gravity="bottom" android:background="#FFB300"/>
        </FrameLayout>
        <ProgressBar android:id="@+id/rightVolumeBar" style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="0dp" android:layout_height="0dp" android:max="100" android:progress="50" android:visibility="gone"/>
        <TextView android:id="@+id/tvVolumeValue" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="50%" android:textColor="#CCFFFFFF" android:textSize="8sp" android:layout_marginTop="4dp"/>
    </LinearLayout>

    <!-- Volume swipe indicator -->
    <LinearLayout android:id="@+id/volumeIndicator" android:layout_width="110dp" android:layout_height="wrap_content"
        android:layout_gravity="center_vertical|end" android:layout_marginEnd="52dp"
        android:orientation="vertical" android:gravity="center" android:background="#CC000000"
        android:padding="10dp" android:visibility="gone">
        <TextView android:id="@+id/tvVolumeIndicator" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="50%" android:textColor="#FFB300" android:textSize="15sp" android:textStyle="bold"/>
        <ProgressBar android:id="@+id/volumeBar" style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent" android:layout_height="6dp"
            android:max="100" android:progress="50" android:progressTint="#FFB300" android:layout_marginTop="6dp"/>
    </LinearLayout>

    <!-- Brightness swipe indicator -->
    <LinearLayout android:id="@+id/brightnessIndicator" android:layout_width="110dp" android:layout_height="wrap_content"
        android:layout_gravity="center_vertical|start" android:layout_marginStart="52dp"
        android:orientation="vertical" android:gravity="center" android:background="#CC000000"
        android:padding="10dp" android:visibility="gone">
        <TextView android:id="@+id/tvBrightnessIndicator" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="50%" android:textColor="#4FC3F7" android:textSize="15sp" android:textStyle="bold"/>
        <ProgressBar android:id="@+id/brightnessBar" style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent" android:layout_height="6dp"
            android:max="100" android:progress="50" android:progressTint="#4FC3F7" android:layout_marginTop="6dp"/>
    </LinearLayout>

    <!-- TOP BAR -->
    <LinearLayout android:id="@+id/topBar" android:layout_width="match_parent" android:layout_height="48dp"
        android:layout_gravity="top" android:background="#CC000000" android:orientation="horizontal"
        android:paddingStart="12dp" android:paddingEnd="12dp" android:gravity="center_vertical"
        android:visibility="invisible" android:alpha="0">
        <ImageButton android:id="@+id/btnBack" android:layout_width="36dp" android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel" android:background="@drawable/btn_circle"
            android:tint="#FFFFFF" android:contentDescription="Back" android:layout_marginEnd="10dp"/>
        <TextView android:id="@+id/tvTitle" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:textColor="#FFFFFF" android:textSize="13sp" android:textStyle="bold"
            android:maxLines="1" android:ellipsize="end"/>
        <TextView android:id="@+id/btnAspectRatio" android:layout_width="wrap_content" android:layout_height="30dp"
            android:text="Fit" android:textColor="#FFFFFF" android:textSize="11sp" android:gravity="center"
            android:paddingStart="10dp" android:paddingEnd="10dp"
            android:background="@drawable/btn_player_control" android:layout_marginStart="8dp"/>
        <TextView android:id="@+id/btnSubtitles" android:layout_width="wrap_content" android:layout_height="30dp"
            android:text="CC" android:textColor="#FFFFFF" android:textSize="11sp" android:textStyle="bold"
            android:gravity="center" android:paddingStart="10dp" android:paddingEnd="10dp"
            android:background="@drawable/btn_player_control" android:layout_marginStart="8dp" android:visibility="gone"/>
        <TextView android:id="@+id/btnSpeed" android:layout_width="wrap_content" android:layout_height="30dp"
            android:text="1x" android:textColor="#FFB300" android:textSize="11sp" android:textStyle="bold"
            android:gravity="center" android:paddingStart="10dp" android:paddingEnd="10dp"
            android:background="@drawable/btn_player_control" android:layout_marginStart="8dp" android:visibility="gone"/>
        <TextView android:id="@+id/btnPip" android:layout_width="wrap_content" android:layout_height="30dp"
            android:text="PiP" android:textColor="#FFFFFF" android:textSize="10sp"
            android:gravity="center" android:paddingStart="10dp" android:paddingEnd="10dp"
            android:background="@drawable/btn_player_control" android:layout_marginStart="8dp" android:visibility="gone"/>
    </LinearLayout>

    <!-- EPG PANEL (Live TV only) -->
    <LinearLayout android:id="@+id/epgPanel" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_gravity="bottom" android:layout_marginBottom="52dp" android:background="#CC000000"
        android:orientation="vertical" android:paddingStart="16dp" android:paddingEnd="16dp"
        android:paddingTop="8dp" android:paddingBottom="8dp" android:visibility="gone">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="4dp">
            <TextView android:id="@+id/tvEpgCurrent" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:textColor="#FFFFFF" android:textSize="12sp" android:textStyle="bold"
                android:maxLines="1" android:ellipsize="end"/>
            <TextView android:id="@+id/tvEpgTime" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#FFB300" android:textSize="11sp" android:layout_marginStart="8dp"/>
        </LinearLayout>
        <ProgressBar android:id="@+id/epgProgressBar" style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent" android:layout_height="4dp" android:max="100" android:progress="0"
            android:progressTint="#FFB300" android:progressBackgroundTint="#33FFFFFF" android:layout_marginBottom="4dp"/>
        <TextView android:id="@+id/tvEpgNext" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="#99FFFFFF" android:textSize="10sp" android:maxLines="1" android:ellipsize="end"/>
    </LinearLayout>

    <!-- SEEK BAR (VOD only) -->
    <LinearLayout android:id="@+id/seekBarSection" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_gravity="bottom" android:layout_marginBottom="52dp" android:orientation="vertical"
        android:paddingStart="16dp" android:paddingEnd="16dp" android:paddingBottom="4dp"
        android:background="#99000000" android:visibility="gone">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="2dp">
            <TextView android:id="@+id/tvCurrentTime" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0:00" android:textColor="#FFFFFF" android:textSize="13sp" android:textStyle="bold"/>
            <Space android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>
            <TextView android:id="@+id/tvRemainingTime" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="- 0:00" android:textColor="#FFFFFF" android:textSize="13sp" android:textStyle="bold"/>
        </LinearLayout>
        <SeekBar android:id="@+id/seekBar" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:max="1000" android:progress="0" android:progressTint="#FFB300"
            android:progressBackgroundTint="#40FFFFFF" android:thumbTint="#FFB300" android:layout_marginBottom="4dp"/>
    </LinearLayout>

    <!-- CENTER CONTROLS -->
    <LinearLayout android:id="@+id/centerControls" android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="center" android:orientation="horizontal" android:gravity="center_vertical"
        android:visibility="invisible" android:alpha="0">
        <TextView android:id="@+id/btnPrev" android:layout_width="52dp" android:layout_height="52dp"
            android:text="&#9198;" android:textSize="26sp" android:gravity="center"
            android:textColor="#FFFFFF" android:alpha="0.85" android:layout_marginEnd="32dp"/>
        <TextView android:id="@+id/btnPlayPause" android:layout_width="64dp" android:layout_height="64dp"
            android:text="&#9208;" android:textSize="32sp" android:gravity="center"
            android:textColor="#FFFFFF" android:background="@drawable/btn_play_circle"/>
        <TextView android:id="@+id/btnNext" android:layout_width="52dp" android:layout_height="52dp"
            android:text="&#9197;" android:textSize="26sp" android:gravity="center"
            android:textColor="#FFFFFF" android:alpha="0.85" android:layout_marginStart="32dp"/>
    </LinearLayout>

    <!-- BOTTOM BAR -->
    <LinearLayout android:id="@+id/bottomBar" android:layout_width="match_parent" android:layout_height="52dp"
        android:layout_gravity="bottom" android:background="#CC000000" android:orientation="horizontal"
        android:paddingStart="16dp" android:paddingEnd="16dp" android:gravity="center_vertical"
        android:visibility="invisible" android:alpha="0">
        <TextView android:id="@+id/tvProgramInfo" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:textColor="#CCFFFFFF" android:textSize="12sp" android:textStyle="bold"
            android:maxLines="1" android:ellipsize="end"/>
        <TextView android:id="@+id/btnAspectRatioBottom" android:layout_width="wrap_content" android:layout_height="30dp"
            android:text="Fit" android:textColor="#FFFFFF" android:textSize="11sp" android:gravity="center"
            android:paddingStart="10dp" android:paddingEnd="10dp"
            android:background="@drawable/btn_player_control" android:layout_marginStart="8dp"/>
        <TextView android:id="@+id/tvLiveBadge" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="LIVE" android:textColor="#FFFFFF" android:textSize="9sp"
            android:background="@drawable/badge_live" android:paddingStart="8dp" android:paddingEnd="8dp"
            android:paddingTop="3dp" android:paddingBottom="3dp" android:layout_marginStart="8dp" android:visibility="gone"/>
    </LinearLayout>

</FrameLayout>
