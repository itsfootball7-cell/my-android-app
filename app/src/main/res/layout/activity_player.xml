<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Video surface -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/playerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:focusable="false"/>

    <!-- Loading spinner -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center"
        android:indeterminateTint="#FFB300"
        android:visibility="gone"/>

    <!-- Error message -->
    <TextView
        android:id="@+id/tvError"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:textColor="#FF5252"
        android:textSize="13sp"
        android:padding="16dp"
        android:visibility="gone"/>

    <!-- Touch overlay (captures gestures) -->
    <View
        android:id="@+id/touchOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- LEFT side: Brightness bar -->
    <LinearLayout
        android:id="@+id/leftBarContainer"
        android:layout_width="40dp"
        android:layout_height="160dp"
        android:layout_gravity="center_vertical|start"
        android:layout_marginStart="24dp"
        android:orientation="vertical"
        android:gravity="bottom|center_horizontal"
        android:visibility="invisible"
        android:alpha="0">

        <TextView
            android:id="@+id/tvBrightnessValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:layout_marginBottom="4dp"/>

        <FrameLayout
            android:layout_width="6dp"
            android:layout_height="140dp"
            android:background="#33FFFFFF">
            <View
                android:id="@+id/leftBrightnessBarFill"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:layout_gravity="bottom"
                android:background="#FFB300"/>
        </FrameLayout>

        <ProgressBar
            android:id="@+id/brightnessBar"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"/>

    </LinearLayout>

    <!-- RIGHT side: Volume bar -->
    <LinearLayout
        android:id="@+id/rightBarContainer"
        android:layout_width="40dp"
        android:layout_height="160dp"
        android:layout_gravity="center_vertical|end"
        android:layout_marginEnd="24dp"
        android:orientation="vertical"
        android:gravity="bottom|center_horizontal"
        android:visibility="invisible"
        android:alpha="0">

        <TextView
            android:id="@+id/tvVolumeValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:layout_marginBottom="4dp"/>

        <FrameLayout
            android:layout_width="6dp"
            android:layout_height="140dp"
            android:background="#33FFFFFF">
            <View
                android:id="@+id/rightVolumeBarFill"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:layout_gravity="bottom"
                android:background="#FFB300"/>
        </FrameLayout>

        <ProgressBar
            android:id="@+id/volumeBar"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"/>

    </LinearLayout>

    <!-- Swipe indicators (fade in during swipe) -->
    <TextView
        android:id="@+id/tvBrightnessIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical|start"
        android:layout_marginStart="80dp"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:background="#88000000"
        android:padding="8dp"
        android:visibility="gone"/>

    <LinearLayout
        android:id="@+id/brightnessIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone">
    </LinearLayout>

    <TextView
        android:id="@+id/tvVolumeIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical|end"
        android:layout_marginEnd="80dp"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:background="#88000000"
        android:padding="8dp"
        android:visibility="gone"/>

    <LinearLayout
        android:id="@+id/volumeIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone">
    </LinearLayout>

    <!-- ── TOP BAR ── -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:background="#AA000000"
        android:visibility="invisible"
        android:alpha="0">

        <!-- Back -->
        <TextView
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="←"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:gravity="center"
            android:layout_marginEnd="8dp"/>

        <!-- Title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"/>

        <!-- LIVE badge -->
        <TextView
            android:id="@+id/tvLiveBadge"
            android:layout_width="wrap_content"
            android:layout_height="22dp"
            android:text=" LIVE "
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="#CCCC0000"
            android:layout_marginEnd="8dp"
            android:visibility="gone"/>

        <!-- Aspect ratio -->
        <TextView
            android:id="@+id/btnAspectRatio"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="⛶ Fit"
            android:textColor="#CCFFFFFF"
            android:textSize="10sp"
            android:gravity="center"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:background="@drawable/btn_player_control"
            android:layout_marginEnd="6dp"/>

        <!-- Sleep Timer — NEW -->
        <TextView
            android:id="@+id/btnSleepTimer"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="⏱"
            android:textColor="#CCFFFFFF"
            android:textSize="14sp"
            android:gravity="center"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:background="@drawable/btn_player_control"
            android:layout_marginEnd="6dp"/>

        <!-- Audio Track — NEW -->
        <TextView
            android:id="@+id/btnAudioTrack"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="🔊"
            android:textColor="#CCFFFFFF"
            android:textSize="14sp"
            android:gravity="center"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:background="@drawable/btn_player_control"
            android:layout_marginEnd="6dp"/>

        <!-- External Player — NEW -->
        <TextView
            android:id="@+id/btnExternalPlayer"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="📱"
            android:textColor="#CCFFFFFF"
            android:textSize="14sp"
            android:gravity="center"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:background="@drawable/btn_player_control"
            android:layout_marginEnd="6dp"/>

        <!-- PiP -->
        <TextView
            android:id="@+id/btnPip"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="⧉"
            android:textColor="#CCFFFFFF"
            android:textSize="16sp"
            android:gravity="center"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:background="@drawable/btn_player_control"
            android:visibility="gone"/>

    </LinearLayout>

    <!-- ── EPG PANEL (bottom of screen, above controls) ── -->
    <LinearLayout
        android:id="@+id/epgPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginBottom="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:background="#AA000000"
        android:visibility="invisible"
        android:alpha="0">

        <!-- Channel logo -->
        <ImageView
            android:id="@+id/ivEpgChannelLogo"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:scaleType="fitCenter"
            android:layout_marginEnd="12dp"/>

        <!-- EPG info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:id="@+id/tvEpgNow"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvEpgTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFB300"
                    android:textSize="10sp"/>

            </LinearLayout>

            <ProgressBar
                android:id="@+id/epgProgressBar"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:max="100"
                android:progressTint="#FFB300"
                android:progressBackgroundTint="#33FFFFFF"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvEpgNext"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#80FFFFFF"
                android:textSize="10sp"/>

        </LinearLayout>

    </LinearLayout>

    <!-- ── SEEK BAR SECTION ── -->
    <LinearLayout
        android:id="@+id/seekBarSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginBottom="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:visibility="invisible"
        android:alpha="0">

        <TextView
            android:id="@+id/tvCurrentTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0:00"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:layout_marginEnd="8dp"/>

        <SeekBar
            android:id="@+id/seekBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:max="1000"
            android:progressTint="#FFB300"
            android:thumbTint="#FFB300"/>

        <TextView
            android:id="@+id/tvRemainingTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="- 0:00"
            android:textColor="#80FFFFFF"
            android:textSize="11sp"
            android:layout_marginStart="8dp"/>

    </LinearLayout>

    <!-- ── BOTTOM BAR ── -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="#AA000000"
        android:visibility="invisible"
        android:alpha="0">

        <TextView
            android:id="@+id/tvProgramInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#80FFFFFF"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end"/>

        <!-- Subtitles (VOD only) -->
        <TextView
            android:id="@+id/btnSubtitles"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="CC"
            android:textColor="#CCFFFFFF"
            android:textSize="11sp"
            android:gravity="center"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:background="@drawable/btn_player_control"
            android:layout_marginEnd="6dp"
            android:visibility="gone"/>

        <!-- Speed (VOD only) -->
        <TextView
            android:id="@+id/btnSpeed"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="⏩ 1x"
            android:textColor="#CCFFFFFF"
            android:textSize="10sp"
            android:gravity="center"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:background="@drawable/btn_player_control"
            android:layout_marginEnd="6dp"
            android:visibility="gone"/>

        <!-- Aspect ratio bottom -->
        <TextView
            android:id="@+id/btnAspectRatioBottom"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="⛶ Fit"
            android:textColor="#CCFFFFFF"
            android:textSize="10sp"
            android:gravity="center"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:background="@drawable/btn_player_control"/>

    </LinearLayout>

    <!-- ── CENTER CONTROLS ── -->
    <LinearLayout
        android:id="@+id/centerControls"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="invisible"
        android:alpha="0">

        <TextView
            android:id="@+id/btnPrev"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:text="⏮"
            android:textSize="22sp"
            android:textColor="#CCFFFFFF"
            android:gravity="center"
            android:background="@drawable/btn_player_control"
            android:layout_marginEnd="24dp"
            android:visibility="invisible"/>

        <TextView
            android:id="@+id/btnPlayPause"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:text="⏸"
            android:textSize="28sp"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:background="@drawable/btn_play_pause"/>

        <TextView
            android:id="@+id/btnNext"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:text="⏭"
            android:textSize="22sp"
            android:textColor="#CCFFFFFF"
            android:gravity="center"
            android:background="@drawable/btn_player_control"
            android:layout_marginStart="24dp"
            android:visibility="invisible"/>

    </LinearLayout>

</FrameLayout>
