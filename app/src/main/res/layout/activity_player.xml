<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Video Player -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/playerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:keepScreenOn="true"/>

    <!-- Full screen touch overlay for gestures -->
    <View
        android:id="@+id/touchOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#00000000"
        android:clickable="true"
        android:focusable="true"/>

    <!-- Buffering -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_gravity="center"
        android:visibility="gone"
        android:indeterminateTint="#FFB300"/>

    <!-- Error -->
    <TextView
        android:id="@+id/tvError"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:textColor="#FFCF6679"
        android:textSize="13sp"
        android:visibility="gone"
        android:padding="12dp"
        android:background="#90000000"/>

    <!-- ═══ LEFT SIDE: BRIGHTNESS BAR (always visible) ═══ -->
    <LinearLayout
        android:layout_width="28dp"
        android:layout_height="200dp"
        android:layout_gravity="center_vertical|start"
        android:layout_marginStart="8dp"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Sun icon -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="☀"
            android:textColor="#CCFFFFFF"
            android:textSize="14sp"
            android:layout_marginBottom="4dp"/>

        <!-- Vertical progress bar (brightness) -->
        <FrameLayout
            android:layout_width="6dp"
            android:layout_height="150dp"
            android:background="#33FFFFFF">

            <!-- Fill bar - controlled programmatically -->
            <View
                android:id="@+id/leftBrightnessBarFill"
                android:layout_width="6dp"
                android:layout_height="75dp"
                android:layout_gravity="bottom"
                android:background="#4FC3F7"/>

        </FrameLayout>

        <!-- Hidden ProgressBar for value tracking -->
        <ProgressBar
            android:id="@+id/leftBrightnessBar"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:max="100"
            android:progress="50"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/tvBrightnessValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="50%"
            android:textColor="#CCFFFFFF"
            android:textSize="8sp"
            android:layout_marginTop="4dp"/>

    </LinearLayout>

    <!-- ═══ RIGHT SIDE: VOLUME BAR (always visible) ═══ -->
    <LinearLayout
        android:layout_width="28dp"
        android:layout_height="200dp"
        android:layout_gravity="center_vertical|end"
        android:layout_marginEnd="8dp"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Volume icon -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔊"
            android:textSize="12sp"
            android:layout_marginBottom="4dp"/>

        <!-- Vertical progress bar (volume) -->
        <FrameLayout
            android:layout_width="6dp"
            android:layout_height="150dp"
            android:background="#33FFFFFF">

            <View
                android:id="@+id/rightVolumeBarFill"
                android:layout_width="6dp"
                android:layout_height="75dp"
                android:layout_gravity="bottom"
                android:background="#FFB300"/>

        </FrameLayout>

        <!-- Hidden ProgressBar for value tracking -->
        <ProgressBar
            android:id="@+id/rightVolumeBar"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:max="100"
            android:progress="50"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/tvVolumeValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="50%"
            android:textColor="#CCFFFFFF"
            android:textSize="8sp"
            android:layout_marginTop="4dp"/>

    </LinearLayout>

    <!-- ═══ CENTER SWIPE INDICATORS (show during swipe) ═══ -->

    <!-- Volume indicator (center right) -->
    <LinearLayout
        android:id="@+id/volumeIndicator"
        android:layout_width="120dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical|end"
        android:layout_marginEnd="50dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#CC000000"
        android:padding="12dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvVolumeIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔊 50%"
            android:textColor="#FFB300"
            android:textSize="16sp"
            android:textStyle="bold"/>

        <ProgressBar
            android:id="@+id/volumeBar"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:max="100"
            android:progress="50"
            android:progressTint="#FFB300"
            android:layout_marginTop="8dp"/>

    </LinearLayout>

    <!-- Brightness indicator (center left) -->
    <LinearLayout
        android:id="@+id/brightnessIndicator"
        android:layout_width="120dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical|start"
        android:layout_marginStart="50dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#CC000000"
        android:padding="12dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvBrightnessIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="☀ 50%"
            android:textColor="#4FC3F7"
            android:textSize="16sp"
            android:textStyle="bold"/>

        <ProgressBar
            android:id="@+id/brightnessBar"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:max="100"
            android:progress="50"
            android:progressTint="#4FC3F7"
            android:layout_marginTop="8dp"/>

    </LinearLayout>

    <!-- Nitro Watermark -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_margin="14dp"
        android:orientation="horizontal"
        android:alpha="0.4">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nitro"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tv"
            android:textColor="#FFB300"
            android:textSize="10sp"
            android:textStyle="bold"
            android:layout_marginStart="2dp"/>
    </LinearLayout>

    <!-- ═══ TOP BAR (auto hides) ═══ -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_gravity="top"
        android:background="#CC000000"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="@drawable/btn_circle"
            android:tint="#FFFFFF"
            android:contentDescription="Back"
            android:layout_marginEnd="10dp"/>

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"/>

        <!-- Quality/Resolution -->
        <TextView
            android:id="@+id/btnResolution"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:text="⚙ Quality"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:gravity="center"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:background="@drawable/btn_player_control"
            android:layout_marginStart="8dp"/>

        <!-- CC Subtitles -->
        <TextView
            android:id="@+id/btnSubtitles"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:text="CC"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:background="@drawable/btn_player_control"
            android:layout_marginStart="8dp"/>

    </LinearLayout>

    <!-- ═══ BOTTOM BAR (auto hides) ═══ -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="bottom"
        android:background="#CC000000"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:gravity="center_vertical">

        <!-- Play/Pause -->
        <TextView
            android:id="@+id/btnPlayPause"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="⏸"
            android:textSize="22sp"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:layout_marginEnd="16dp"/>

        <!-- Channel/Movie title -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:id="@+id/tvProgramInfo"
            android:textColor="#CCFFFFFF"
            android:textSize="11sp"/>

        <!-- Live badge -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● LIVE"
            android:textColor="#FFFFFF"
            android:textSize="9sp"
            android:background="@drawable/badge_live"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"/>

    </LinearLayout>

</FrameLayout>
