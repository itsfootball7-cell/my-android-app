<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#000000">
<!--  Video Player  -->
<androidx.media3.ui.PlayerView android:id="@+id/playerView" android:layout_width="match_parent" android:layout_height="match_parent" android:keepScreenOn="true"/>
<!--  Buffering  -->
<ProgressBar android:id="@+id/progressBar" android:layout_width="52dp" android:layout_height="52dp" android:layout_gravity="center" android:visibility="gone" android:indeterminateTint="#FFB300"/>
<!--  Error  -->
<TextView android:id="@+id/tvError" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:textColor="#FFCF6679" android:textSize="13sp" android:visibility="gone" android:padding="12dp" android:background="#90000000"/>
<!--  Nitro Watermark  -->
<LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="top|start" android:layout_margin="14dp" android:orientation="horizontal" android:alpha="0.4" android:clickable="false">
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Nitro" android:textColor="#FFFFFF" android:textSize="12sp" android:textStyle="bold"/>
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tv" android:textColor="#FFB300" android:textSize="10sp" android:textStyle="bold" android:layout_marginStart="2dp"/>
</LinearLayout>
<!--  TOP BAR  -->
<LinearLayout android:id="@+id/topBar" android:layout_width="match_parent" android:layout_height="48dp" android:layout_gravity="top" android:background="#CC000000" android:orientation="horizontal" android:paddingStart="12dp" android:paddingEnd="12dp" android:gravity="center_vertical">
<ImageButton android:id="@+id/btnBack" android:layout_width="36dp" android:layout_height="36dp" android:src="@android:drawable/ic_menu_close_clear_cancel" android:background="@drawable/btn_circle" android:tint="#FFFFFF" android:contentDescription="Back" android:layout_marginEnd="12dp"/>
<TextView android:id="@+id/tvTitle" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textColor="#FFFFFF" android:textSize="13sp" android:textStyle="bold" android:maxLines="1" android:ellipsize="end"/>
<!--  Quality button  -->
<TextView android:id="@+id/btnResolution" android:layout_width="wrap_content" android:layout_height="30dp" android:text="⚙ Quality" android:textColor="#FFFFFF" android:textSize="11sp" android:gravity="center" android:paddingStart="10dp" android:paddingEnd="10dp" android:background="@drawable/btn_player_control" android:layout_marginStart="8dp"/>
<!--  CC Subtitles button  -->
<TextView android:id="@+id/btnSubtitles" android:layout_width="wrap_content" android:layout_height="30dp" android:text="CC" android:textColor="#FFFFFF" android:textSize="11sp" android:textStyle="bold" android:gravity="center" android:paddingStart="10dp" android:paddingEnd="10dp" android:background="@drawable/btn_player_control" android:layout_marginStart="8dp"/>
</LinearLayout>
<!--  LEFT PANEL: Volume  -->
<LinearLayout android:id="@+id/leftPanel" android:layout_width="56dp" android:layout_height="220dp" android:layout_gravity="center_vertical|start" android:layout_marginStart="12dp" android:orientation="vertical" android:gravity="center_horizontal" android:background="#99000000" android:padding="8dp">
<TextView android:id="@+id/tvVolumeLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🔊 50%" android:textColor="#FFB300" android:textSize="9sp" android:layout_marginBottom="8dp"/>
<!--  Rotated horizontal SeekBar to look vertical  -->
<FrameLayout android:layout_width="40dp" android:layout_height="160dp" android:layout_gravity="center_horizontal">
<SeekBar android:id="@+id/seekVolume" android:layout_width="150dp" android:layout_height="wrap_content" android:layout_gravity="center" android:rotation="-90" android:translationX="-55dp" android:progressTint="#FFB300" android:thumbTint="#FFB300" android:progressBackgroundTint="#40FFFFFF"/>
</FrameLayout>
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="VOL" android:textColor="#80FFFFFF" android:textSize="8sp" android:layout_marginTop="8dp"/>
</LinearLayout>
<!--  RIGHT PANEL: Brightness  -->
<LinearLayout android:id="@+id/rightPanel" android:layout_width="56dp" android:layout_height="220dp" android:layout_gravity="center_vertical|end" android:layout_marginEnd="12dp" android:orientation="vertical" android:gravity="center_horizontal" android:background="#99000000" android:padding="8dp">
<TextView android:id="@+id/tvBrightnessLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="☀ 50%" android:textColor="#4FC3F7" android:textSize="9sp" android:layout_marginBottom="8dp"/>
<FrameLayout android:layout_width="40dp" android:layout_height="160dp" android:layout_gravity="center_horizontal">
<SeekBar android:id="@+id/seekBrightness" android:layout_width="150dp" android:layout_height="wrap_content" android:layout_gravity="center" android:rotation="-90" android:translationX="-55dp" android:progressTint="#4FC3F7" android:thumbTint="#4FC3F7" android:progressBackgroundTint="#40FFFFFF"/>
</FrameLayout>
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="BRT" android:textColor="#80FFFFFF" android:textSize="8sp" android:layout_marginTop="8dp"/>
</LinearLayout>
<!--  CENTER: Play/Pause  -->
<ImageButton android:id="@+id/btnPlayPause" android:layout_width="60dp" android:layout_height="60dp" android:layout_gravity="center" android:src="@android:drawable/ic_media_pause" android:background="@drawable/btn_play_circle" android:tint="#FFFFFF" android:contentDescription="Play Pause"/>
<!--  BOTTOM CONTROLS  -->
<LinearLayout android:id="@+id/controlsOverlay" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_gravity="bottom" android:background="#CC000000" android:orientation="horizontal" android:padding="10dp" android:gravity="center_vertical">
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="● LIVE" android:textColor="#FFFFFF" android:textSize="9sp" android:background="@drawable/badge_live" android:paddingStart="8dp" android:paddingEnd="8dp" android:paddingTop="3dp" android:paddingBottom="3dp" android:layout_marginEnd="10dp"/>
<TextView android:id="@+id/tvProgramInfo" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textColor="#CCFFFFFF" android:textSize="11sp" android:text=""/>
</LinearLayout>
</FrameLayout>
